)

#cool welcome message in a nice cyan color
startup() {
  clear
  echo ""
  echo -e "${cyan}${bigtext[($RANDOM % 7)]}${blank}"

  for x in {1..4}; do
    sleep 0.5
    echo "initializing content [${x}/4]"
  done
  sleep 1
  echo ""
  for y in {1..16}; do
    sleep 0.01
    echo "loading [${y}/16]"
  done
  sleep 2
}

#this gives the user sometihng to look at while the script runs its magic.
search() {
  echo ""
  echo -e "${cyan}----------<<Welcome to IPscanner>>----------${blank}"
  echo -e "${green}Your address is:${blank}"
  echo -e "${red}$network${blank}"
  echo ""
  sleep 1.5
  echo -e "Now searching for addresses on the network: ${purple}${network%.*}.x${blank}" #"\e[35${network%.*}\e[0m")
  sleep 2.5
}

#This is where the magic actually happens.
scan() {
  for ip in {1..254}; do          #this is to go trough every address from 1 to 254 and put it in a variable named "ip"
    address="${network%.*}.${ip}" # this is to add the "ip" variable to the "network" varable so we get something like 192.168.20.IP

    ping -c 1 -W 0.3 "${address}" >/dev/null 2>&1 #This is the thingy that pings an address and looks for a response

    if [ $? -eq 0 ]; then # this looks for adresses that did not respond

      if [ ${ip} -lt 10 ]; then
        echo -e "${address} ${green}  [up]${blank}--------- ${ip}/254"

      elif [ ${ip} -lt 255 ] && [ ${ip} -gt 9 ]; then
        echo -e "${address} ${green} [up]${blank}-------- ${ip}/254"

      elif [ ${ip} -lt 255 ] && [ ${ip} -gt 99]; then
        echo -e "${address} ${green} [up]${blank}----- ${ip}/254"

      fi

    elif [ $? -ne 0 ]; then

      if [ ${ip} -lt 10 ]; then
        echo -e "${address} ${red} [down]${blank}-------- ${ip}/254"

      elif [ ${ip} -lt 255 ] && [ ${ip} -gt 9 ]; then
        echo -e "${address} ${red}[down]${blank}------- ${ip}/254"

      elif [ ${ip} -lt 255 ] && [ ${ip} -gt 99]; then
        echo -e "${address} ${red}[down]${blank}---- ${ip}/254"

      fi
    fi

    ((count += 1)) #this is just to show how many times the code ran. other words, how many adresses was pinged.
  done
}

# This is where we call the functions and in order
startup
search
wait
scan
wait

#and, can't forget the line that tells the user how many addresses was checked
echo -e "\e[33mscanned: $count addresses\e[0m"
