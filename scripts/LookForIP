#!/etc/bash

#global shit like array and variables
count=0
red="\e[31m"
green="\e[32m"
purple="\e[35m"
cyan="\e[36m"
blank="\e[0m"

#this one look scary, but it's just cutting the result of running "ifcinfig eno1" to only display the ip
#network=$(ifconfig eno1 | grep "inet " | cut -d " " -f 10) # <--- This only woks with "net-tools" and olnly if you're using eno1. not practical
network=$(ip route get 1.1.1.1 | grep -oP "src \K\S+") # This is supposed to see what you use, Like: eth0, wlan0, enp3s0,

bigtext=('
  mmmmmm   mmmmmm                                                                         
